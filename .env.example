# Required for first Garmin login (or when tokens expire)
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Optional token cache path (default: data/.garmin_tokens)
GARMIN_TOKENSTORE=data/.garmin_tokens

# Optional override (default: data/garmin_strength.db)
SQLITE_PATH=data/garmin_strength.db
